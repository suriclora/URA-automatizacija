# PRIMJER .env datoteke (BEZ pravih tajni).
# Kopiraj u ".env" i upiši stvarne vrijednosti. ".env" se NIKAD ne dijeli (vidi .gitignore).

# --- Način rada ---
# DEMO=1  -> radi na izmišljenim podacima (demo/data), ne treba ništa od dolje.
# DEMO=0  -> pravi rad: popuni vrijednosti ispod.
DEMO=1

# --- Parra API (računovodstveni servis) ---
PARRA_API_TOKEN=ovdje_ide_tvoj_token
PARRA_BUSINESS_ID=00000
PARRA_BASE_URL=https://api.parra.hr/v1.1

# --- Tajne / identifikatori ---
PN_LOZINKA=lozinka_zastite_excela
MOJ_OIB=12345678901

# --- Putanje (samo za DEMO=0; primjeri su generički) ---
EXCEL_PATH=\\SERVER\Financije\URA_2026.xlsm
FOLDER_PDF_FINAL=\\SERVER\Financije\Racuni\pdf
FOLDER_PARRA=\\SERVER\Financije\Racuni\Parra
FOLDER_IZVODI_HPB=\\SERVER\Financije\Izvodi\HPB
FOLDER_IZVODI_RBA=\\SERVER\Financije\Izvodi\RBA
FOLDER_PN=\\SERVER\Financije\PN
TERENI_PATH=\\SERVER\share\tereni.xlsx
BACKUP_DIR=\\SERVER\Financije\Backup
